{
  "name": "precision-pulse",
  "version": "1.3.1",
  "description": "Precision Pulse - Professional Broadcast Timer",
  "main": "main.js",
  "author": "Antigravity",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder --win"
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^23.6.0",
    "electron-packager": "^17.1.2",
    "javascript-obfuscator": "^5.4.2"
  },
  "build": {
    "appId": "com.broadcast.precisionpulse",
    "productName": "Precision Pulse",
    "cscLink": null,
    "icon": "icon.ico",
    "win": {
      "target": "nsis",
      "icon": "icon.ico",
      "publish": [
        {
          "provider": "generic",
          "url": "https://amaudiovisuals.com/updates/"
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerIcon": "icon.ico",
      "uninstallerIcon": "icon.ico",
      "installerSidebar": "installer_sidebar.png",
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "Precision Pulse"
    },
    "extraResources": [
      {
        "from": "Buzzer sounds",
        "to": "Buzzer sounds"
      }
    ],
    "files": [
      "main.js",
      "bundle.html",
      "projector.html",
      "package.json",
      "licensing.js",
      "logo.png",
      "precisionlogo.png",
      "amlogo.png",
      "fonts/**/*",
      "icon.ico",
      "installer_sidebar.png"
    ],
    "directories": {
      "output": "dist"
    }
  },
  "dependencies": {
    "electron-updater": "^6.8.3",
    "node-machine-id": "^1.1.12",
    "png-to-ico": "^3.0.1",
    "png2icons": "^2.0.1"
  }
}
